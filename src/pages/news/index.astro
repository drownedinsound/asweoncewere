---
import Layout from '../../layouts/Layout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const news = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="News — The Anchoress">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="font-headline text-3xl tracking-[2px] uppercase text-cream mb-10">News</h1>
    <div>
      {news.map((post) => <NewsCard slug={post.id} title={post.data.title} date={post.data.date} image={post.data.image} />)}
    </div>
  </section>
</Layout>
