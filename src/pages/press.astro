---
import Layout from '../layouts/Layout.astro';
import PressQuote from '../components/PressQuote.astro';
import { getCollection } from 'astro:content';

const quotes = await getCollection('press');
const byAlbum = new Map<string, typeof quotes>();
for (const q of quotes) {
  const key = q.data.forAlbum ?? 'As We Once Were';
  if (!byAlbum.has(key)) byAlbum.set(key, []);
  byAlbum.get(key)!.push(q);
}
---

<Layout title="Press — The Anchoress">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-headline text-3xl tracking-[2px] uppercase text-cream mb-12">Press</h1>
    {[...byAlbum.entries()].map(([album, group]) => (
      <div class="mb-16">
        <h2 class="font-label text-xs tracking-[2px] uppercase text-white/40 mb-6">Praise for {album}</h2>
        <div class="space-y-8">
          {group.map((q) => <PressQuote quote={q.data.quote} source={q.data.source} />)}
        </div>
      </div>
    ))}
  </section>
</Layout>
