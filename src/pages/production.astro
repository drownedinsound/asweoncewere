---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import { paragraphs } from '../lib/text';

const bio = (await getEntry('bio', 'bio'))!.data;
const paras = paragraphs(bio.production);
---

<Layout title="Production / Co-writing — The Anchoress">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-headline text-3xl tracking-[2px] uppercase text-cream mb-10">
      Catherine Anne Davies — Production &amp; Co-Writing
    </h1>
    <img
      src="/images/gallery/roberto-foddai-1.webp"
      alt="Catherine Anne Davies in the studio"
      class="w-full max-w-sm mx-auto mb-10"
      loading="lazy"
    />
    <div class="font-body text-white/90 leading-relaxed space-y-5 [&_strong]:font-headline [&_strong]:uppercase [&_strong]:tracking-wide [&_strong]:text-cream [&_strong]:text-sm [&_strong]:block [&_strong]:mt-8 [&_strong]:mb-1">
      {paras.map((p) => <p set:html={p} />)}
    </div>
  </section>
</Layout>
