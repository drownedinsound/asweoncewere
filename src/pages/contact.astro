---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const settings = (await getEntry('settings', 'settings'))!.data;
---

<Layout title="Contact — The Anchoress">
  <section class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="font-headline text-3xl tracking-[2px] uppercase text-cream mb-12">Contact</h1>
    <div class="space-y-10">
      {settings.contacts.map((c) => (
        <div>
          <p class="font-label text-xs tracking-[2px] uppercase text-white/40">{c.label}</p>
          {c.name && <p class="font-headline text-lg uppercase text-white mt-1">{c.name}</p>}
          <a href={`mailto:${c.email}`} class="font-body italic text-cream hover:underline">{c.email}</a>
        </div>
      ))}
    </div>
  </section>
</Layout>
