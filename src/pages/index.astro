---
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import PressQuote from '../components/PressQuote.astro';
import { getCollection, getEntry } from 'astro:content';
import { fetchSubstackPosts } from '../lib/substack';
import { youtubeEmbedSrc, youtubeVideoId } from '../lib/youtube';
import YouTubeFacade from '../components/YouTubeFacade.astro';
import { paragraphs } from '../lib/text';

const settings = (await getEntry('settings', 'settings'))!.data;
const bio = (await getEntry('bio', 'bio'))!.data;
const news = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestNews = news.slice(0, 9);
const tourDates = (await getCollection('tourDates')).sort(
  (a, b) => new Date(a.data.date).valueOf() - new Date(b.data.date).valueOf()
);
const substackPosts = await fetchSubstackPosts(new URL('feed', settings.substackUrl).toString());
const productionParas = paragraphs(bio.production);
const biogParas = paragraphs(bio.biog);

const quotes = await getCollection('press');
const byAlbum = new Map<string, typeof quotes>();
for (const q of quotes) {
  const key = q.data.forAlbum ?? 'As We Once Were';
  if (!byAlbum.has(key)) byAlbum.set(key, []);
  byAlbum.get(key)!.push(q);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicAlbum',
  name: 'As We Once Were',
  byArtist: {
    '@type': 'MusicGroup',
    name: 'The Anchoress',
    alternateName: 'Catherine Anne Davies',
    url: 'https://asweoncewere.com/',
  },
  datePublished: '2026-08-07',
  numTracks: 14,
  recordLabel: {
    '@type': 'Organization',
    name: 'Last Night From Glasgow',
  },
  description: 'The third studio album from The Anchoress (Catherine Anne Davies), out August 7th 2026 via Last Night From Glasgow.',
  url: 'https://asweoncewere.com/',
  image: 'https://asweoncewere.com/og-image.jpg',
};
---

<Layout title="The Anchoress">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="max-w-4xl mx-auto px-6 mt-10">
    <YouTubeFacade
      embedSrc={youtubeEmbedSrc(settings.heroVideoUrl)}
      videoId={youtubeVideoId(settings.heroVideoUrl)}
      title="The Anchoress"
    />
  </div>

  <div class="max-w-2xl mx-auto px-6 mt-10 text-center">
    <p class="font-label text-xs tracking-[2px] uppercase text-white/40 mb-3">As We Once Were, The Third Studio Album From The Anchoress</p>
    <p class="font-headline text-xl md:text-2xl uppercase text-cream leading-snug">
      "Her most sonically adventurous record yet." <span class="text-white/40 normal-case tracking-normal font-body italic text-base align-middle">NME</span>
    </p>
  </div>

  <div class="max-w-4xl mx-auto px-6 mt-16">
    <a href={settings.preorderUrl} target="_blank" rel="noopener noreferrer" class="block hover:opacity-90 transition-opacity">
      <img
        src="/images/album-formats.webp"
        alt="As We Once Were, available on 2LP vinyl, cassette, CD, and deluxe mediabook"
        loading="lazy"
        class="w-full"
      />
    </a>
  </div>

  <div class="border border-white/20 max-w-4xl mx-auto mt-10 mx-6">
    <a
      href={settings.preorderUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block text-center font-label text-xs md:text-sm tracking-[2px] uppercase py-5 px-6 text-white hover:text-cream transition-colors"
    >
      {settings.preorderText}
    </a>
  </div>

  <div class="max-w-4xl mx-auto px-6 mt-6 flex justify-center">
    <a
      href={new URL('subscribe', settings.substackUrl).toString()}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block bg-cream text-ink font-label text-xs tracking-[2px] uppercase px-8 py-4 hover:bg-white transition-colors"
    >
      Join the Mailing List
    </a>
  </div>

  <section id="news" class="max-w-4xl mx-auto px-6 mt-20 scroll-mt-8">
    <div class="flex items-baseline justify-between">
      <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream">News</h2>
      <a href="/news" class="font-label text-xs tracking-[2px] uppercase text-white/50 hover:text-white transition-colors">More News →</a>
    </div>
    <div class="mt-6">
      {latestNews.map((post) => <NewsCard slug={post.id} title={post.data.title} date={post.data.date} image={post.data.image} />)}
    </div>
    <div class="mt-8 text-center">
      <a href="/news" class="inline-block font-label text-xs tracking-[2px] uppercase border border-white/40 px-6 py-3 text-white hover:bg-white hover:text-ink transition-colors">
        More News
      </a>
    </div>
  </section>

  {substackPosts.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 mt-20">
      <div class="flex items-baseline justify-between">
        <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream">From the Newsletter</h2>
        <a href={settings.substackUrl} target="_blank" rel="noopener noreferrer" class="font-label text-xs tracking-[2px] uppercase text-white/50 hover:text-white transition-colors">
          Visit Substack →
        </a>
      </div>
      <div class="mt-6 grid sm:grid-cols-2 gap-6">
        {substackPosts.map((post) => (
          <a href={post.link} target="_blank" rel="noopener noreferrer" class="block border border-white/10 hover:border-white/30 transition-colors group">
            {post.image && (
              <img src={post.image} alt="" loading="lazy" class="w-full aspect-video object-cover" />
            )}
            <div class="p-5">
              <p class="font-label text-xs tracking-[2px] uppercase text-white/40">
                {new Date(post.pubDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </p>
              <h3 class="font-headline text-lg uppercase tracking-tight text-white mt-2 group-hover:text-cream transition-colors">
                {post.title}
              </h3>
              {post.excerpt && <p class="font-body italic text-white/60 mt-2 text-sm">{post.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="max-w-4xl mx-auto px-6 mt-16 flex justify-center">
    <a
      href={new URL('subscribe', settings.substackUrl).toString()}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block bg-cream text-ink font-label text-xs tracking-[2px] uppercase px-8 py-4 hover:bg-white transition-colors"
    >
      Join the Mailing List
    </a>
  </div>

  <section id="live" class="max-w-4xl mx-auto px-6 mt-20 scroll-mt-8">
    <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream">Tour Dates</h2>
    {tourDates.length === 0 && <p class="text-white/60 font-body italic mt-6">No upcoming dates announced right now — check back soon.</p>}
    <div class="mt-6 divide-y divide-white/10">
      {tourDates.map((event) => {
        const d = new Date(event.data.date);
        return (
          <div class="py-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div>
              <p class="font-label text-xs tracking-[2px] uppercase text-white/40">
                {d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
              </p>
              <p class="font-headline text-lg uppercase tracking-tight text-white mt-1">{event.data.title}</p>
              <p class="font-body italic text-white/60 mt-1">{event.data.location}</p>
            </div>
            <div class="flex gap-3">
              {event.data.ticketUrl && (
                <a href={event.data.ticketUrl} target="_blank" rel="noopener noreferrer" class="font-label text-xs tracking-[2px] uppercase border border-white/40 px-5 py-3 text-white hover:bg-white hover:text-ink transition-colors">
                  Tickets
                </a>
              )}
              {event.data.rsvpUrl && (
                <a href={event.data.rsvpUrl} target="_blank" rel="noopener noreferrer" class="font-label text-xs tracking-[2px] uppercase border border-white/40 px-5 py-3 text-white hover:bg-white hover:text-ink transition-colors">
                  RSVP
                </a>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section id="production" class="relative mt-20 scroll-mt-8 overflow-hidden">
    <img
      src="/images/gallery/sean-adams-studio-1.webp"
      alt=""
      aria-hidden="true"
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-ink/55"></div>
    <div class="relative max-w-2xl mx-auto px-6 py-16">
      <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream mb-10">
        Catherine Anne Davies — Production &amp; Co-Writing
      </h2>
      <img
        src="/images/gallery/roberto-foddai-1.webp"
        alt="Catherine Anne Davies in the studio"
        class="w-full mb-10"
        loading="lazy"
      />
      <div class="font-body text-lg text-white/90 leading-relaxed space-y-5 [&_strong]:font-headline [&_strong]:uppercase [&_strong]:tracking-wide [&_strong]:text-cream [&_strong]:text-sm [&_strong]:block [&_strong]:mt-8 [&_strong]:mb-1">
        {productionParas.map((p) => <p set:html={p} />)}
      </div>
    </div>
  </section>

  <section id="tracklist" class="max-w-2xl mx-auto px-6 mt-20 scroll-mt-8">
    <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream mb-2">As We Once Were</h2>
    <p class="font-label text-xs tracking-[2px] uppercase text-white/40 mb-10">14 Tracks &middot; 57:48</p>
    <ol class="space-y-4">
      {[
        { title: 'Du Temps Perdu (Introduction)' },
        { title: 'Throw Over Your Man', feat: 'James Dean Bradfield' },
        { title: 'I Had A Baby Not A Lobotomy', feat: 'Gwenno' },
        { title: 'Damsels', feat: 'Eaves Wilder' },
        { title: 'As We Once Were' },
        { title: "Happiness Don't Show Up Like It Should (Prologue)" },
        { title: 'All I Really Want Is Peace' },
        { title: 'Stop The World' },
        { title: 'Du Temps Perdu (Reprise)' },
        { title: 'What You Did' },
        { title: 'All Fall Down', feat: 'Hannah Peel' },
        { title: 'Hand To The Tide' },
        { title: 'She Knows Her Place' },
        { title: "Happiness Don't Show Up Like It (Epilogue)" },
      ].map((track, i) => (
        <li class="flex items-baseline gap-4 py-3 border-b border-white/10">
          <span class="font-label text-xs text-white/30 w-6 flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
          <span class="flex-1">
            <span class="font-headline text-base md:text-lg uppercase tracking-tight text-white">{track.title}</span>
            {track.feat && <span class="font-body italic text-white/50 text-sm ml-2">feat. {track.feat}</span>}
          </span>
        </li>
      ))}
    </ol>
  </section>

  <section id="press" class="relative mt-20 scroll-mt-8 overflow-hidden">
    <img
      src="/images/gallery/isabella-charlesworth-2.webp"
      alt=""
      aria-hidden="true"
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-ink/55"></div>
    <div class="relative max-w-3xl mx-auto px-6 py-16">
      <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream mb-12">Press</h2>
      {[...byAlbum.entries()].map(([album, group], i) => (
        <details class="mb-6 group" open={i === 0}>
          <summary class="font-label text-xs tracking-[2px] uppercase text-white/50 hover:text-white mb-6 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden flex items-center gap-2 transition-colors">
            <span class="inline-block transition-transform group-open:rotate-90">→</span>
            Praise for {album}
            <span class="text-white/25 normal-case tracking-normal">({group.length})</span>
          </summary>
          <div class="space-y-8 mt-6 pb-4">
            {group.map((q) => <PressQuote quote={q.data.quote} source={q.data.source} sourceUrl={q.data.sourceUrl} />)}
          </div>
        </details>
      ))}
    </div>
  </section>

  <section id="biog" class="relative mt-20 scroll-mt-8 overflow-hidden">
    <img
      src="/images/gallery/annick-wolfers-1.webp"
      alt=""
      aria-hidden="true"
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-ink/55"></div>
    <div class="relative max-w-2xl mx-auto px-6 py-16">
      <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream mb-10">The Anchoress</h2>
      <img
        src="/images/gallery/isabella-charlesworth-1.webp"
        alt="The Anchoress, photo by Isabella Charlesworth"
        class="w-full mb-10"
        loading="lazy"
      />
      <div class="font-body text-lg text-white/90 leading-relaxed space-y-5 italic [&_strong]:not-italic">
        {biogParas.map((p) => <p set:html={p} />)}
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 mt-20">
    <h2 class="font-headline text-2xl tracking-[2px] uppercase text-cream mb-6">Photos</h2>
    <PhotoGallery />
  </section>

  <div class="max-w-2xl mx-auto px-6 mt-20 pb-20">
    <p class="font-label text-xs tracking-[2px] uppercase text-white/40 mb-4 text-center">Watch: The Exchange, feat. James Dean Bradfield</p>
    <YouTubeFacade
      embedSrc={youtubeEmbedSrc('https://www.youtube.com/watch?v=HLFqdfYeVJ4')}
      videoId="HLFqdfYeVJ4"
      title="The Exchange, The Anchoress feat. James Dean Bradfield"
    />
  </div>
</Layout>
